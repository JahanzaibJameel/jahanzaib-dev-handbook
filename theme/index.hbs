<!DOCTYPE html>
<html lang="{{ language }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <title>{{ title }}</title>
    <base href="/">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="192x192" href="/icon-192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="{{ path_to_root }}custom.css">
    <script src="{{ path_to_root }}custom.js" defer></script>
    {{{ print }}}
    {{{ scripts }}}
    
    <!-- Critical CSS for immediate styling -->
    <style>
        :root {
            --space-0: 0;
            --space-1: 0.25rem;
            --space-2: 0.5rem;
            --space-3: 0.75rem;
            --space-4: 1rem;
            --space-6: 1.5rem;
            --space-8: 2rem;
            --space-12: 3rem;
            --space-16: 4rem;
            
            --radius-sm: 0.25rem;
            --radius-md: 0.375rem;
            --radius-lg: 0.5rem;
            --radius-xl: 0.75rem;
            
            --text-xs: 0.75rem;
            --text-sm: 0.875rem;
            --text-base: 1rem;
            --text-lg: 1.125rem;
            --text-xl: 1.25rem;
            --text-2xl: 1.5rem;
            --text-3xl: 1.875rem;
            --text-4xl: 2.25rem;
            
            --font-weight-normal: 400;
            --font-weight-medium: 500;
            --font-weight-semibold: 600;
            --font-weight-bold: 700;
            
            --transition-fast: 150ms ease;
            --transition-normal: 300ms ease;
            
            --z-sticky: 1000;
            --z-modal: 9999;
            
            --container-2xl: 1400px;
            
            --leading-normal: 1.5;
            --leading-relaxed: 1.625;
            --leading-tight: 1.25;
            
            --font-sans: 'Inter Variable', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --font-mono: 'JetBrains Mono Variable', 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, monospace;
            
            --bg-primary: oklch(98% 0.005 250);
            --bg-secondary: oklch(100% 0 0);
            --bg-tertiary: oklch(96% 0.01 250);
            --bg-glass: oklch(100% 0 0 / 0.8);
            --bg-overlay: oklch(0% 0 0 / 0.5);
            --bg-code: oklch(94% 0.02 250);
            
            --text-primary: oklch(20% 0.02 260);
            --text-secondary: oklch(40% 0.01 250);
            --text-code: oklch(25% 0.03 250);
            
            --accent-primary: oklch(60% 0.2 250);
            --accent-primary-hover: oklch(65% 0.22 250);
            
            --border-light: oklch(85% 0.01 250);
            --border-medium: oklch(75% 0.01 250);
            
            --shadow-sm: 0 1px 3px 0 oklch(0% 0 0 / 0.1), 0 1px 2px 0 oklch(0% 0 0 / 0.06);
            --shadow-md: 0 4px 6px -1px oklch(0% 0 0 / 0.1), 0 2px 4px -1px oklch(0% 0 0 / 0.06);
            --shadow-xl: 0 20px 25px -5px oklch(0% 0 0 / 0.1), 0 10px 10px -5px oklch(0% 0 0 / 0.04);
        }
        
        * {
            box-sizing: border-box;
        }
        
        body {
            margin: 0;
            padding: 0;
            font-family: var(--font-sans);
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: var(--leading-normal);
        }
        
        .devatelier-theme {
            min-height: 100vh;
            display: grid;
            grid-template-rows: auto 1fr auto;
        }
        
        .header {
            position: sticky;
            top: 0;
            z-index: var(--z-sticky);
            background-color: var(--bg-glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-light);
            padding: var(--space-4) 0;
        }
        
        .header-container {
            max-width: var(--container-2xl);
            margin: 0 auto;
            padding: 0 var(--space-6);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: var(--space-6);
        }
        
        .header-title {
            font-size: var(--text-xl);
            font-weight: var(--font-weight-bold);
            color: var(--text-primary);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: var(--space-3);
        }
        
        .main-container {
            max-width: var(--container-2xl);
            margin: 0 auto;
            padding: var(--space-8) var(--space-6);
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: var(--space-8);
        }
        
        @media (min-width: 1024px) {
            .main-container {
                grid-template-columns: 280px minmax(0, 1fr);
            }
        }
        
        @media (min-width: 1280px) {
            .main-container {
                grid-template-columns: 320px minmax(0, 1fr);
            }
        }
        
        .sidebar {
            grid-column: 1;
            order: 2;
            height: fit-content;
            position: sticky;
            top: calc(var(--space-16) + var(--space-4));
            overflow-y: auto;
            max-height: calc(100vh - var(--space-16) - var(--space-8));
        }
        
        @media (min-width: 1024px) {
            .sidebar {
                order: 1;
            }
        }
        
        .sidebar-content {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: var(--space-6);
            box-shadow: var(--shadow-sm);
        }
        
        .sidebar-nav {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .sidebar-nav a {
            display: block;
            padding: var(--space-2) var(--space-3);
            border-radius: var(--radius-md);
            color: var(--text-secondary);
            text-decoration: none;
            transition: all var(--transition-fast);
            font-size: var(--text-sm);
            position: relative;
            overflow: hidden;
        }
        
        .sidebar-nav a:hover,
        .sidebar-nav a.active {
            background-color: var(--bg-tertiary);
            color: var(--text-primary);
        }
        
        .sidebar-nav a.active {
            background-color: var(--accent-primary / 0.1);
            color: var(--accent-primary);
            font-weight: var(--font-weight-medium);
        }
        
        .sidebar-nav a.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background-color: var(--accent-primary);
        }
        
        .content {
            grid-column: 2;
            order: 1;
            min-width: 0;
        }
        
        @media (min-width: 1024px) {
            .content {
                order: 2;
            }
        }
        
        .content-inner {
            max-width: none;
            margin: 0;
        }
        
        article {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-xl);
            padding: var(--space-8);
            box-shadow: var(--shadow-sm);
            margin-bottom: var(--space-8);
        }
        
        .article-header h1 {
            font-size: var(--text-4xl);
            font-weight: var(--font-weight-bold);
            color: var(--text-primary);
            margin-bottom: var(--space-4);
            scroll-margin: calc(var(--space-16) + var(--space-4));
        }
        
        .article-content {
            color: var(--text-secondary);
            line-height: var(--leading-relaxed);
        }
        
        .article-content h1,
        .article-content h2,
        .article-content h3,
        .article-content h4,
        .article-content h5,
        .article-content h6 {
            color: var(--text-primary);
            margin-bottom: var(--space-4);
        }
        
        .article-content p {
            margin-bottom: var(--space-4);
            max-width: 65ch;
        }
        
        .footer {
            grid-row: 3;
            background-color: var(--bg-tertiary);
            border-top: 1px solid var(--border-light);
            padding: var(--space-8) 0;
            margin-top: auto;
        }
        
        .footer-container {
            max-width: var(--container-2xl);
            margin: 0 auto;
            padding: 0 var(--space-6);
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: var(--space-8);
        }
        
        .footer-section h3 {
            font-size: var(--text-base);
            font-weight: var(--font-weight-semibold);
            margin-bottom: var(--space-4);
            color: var(--text-primary);
        }
        
        .footer-section p,
        .footer-section ul {
            font-size: var(--text-sm);
            color: var(--text-secondary);
            margin-bottom: 0;
        }
        
        .footer-section ul {
            list-style: none;
            padding-left: 0;
        }
        
        .footer-section a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: color var(--transition-fast);
        }
        
        .footer-section a:hover {
            color: var(--accent-primary);
        }
        
        .skip-link {
            position: absolute;
            top: -40px;
            left: 6px;
            background: var(--accent-primary);
            color: white;
            padding: 8px;
            text-decoration: none;
            border-radius: 4px;
            z-index: 10000;
            font-weight: 500;
        }
        
        .skip-link:focus {
            top: 6px;
        }
        
        /* Basic element styling */
        h1, h2, h3, h4, h5, h6 {
            font-weight: var(--font-weight-semibold);
            line-height: var(--leading-tight);
            color: var(--text-primary);
            margin-bottom: var(--space-4);
        }
        
        p {
            margin-bottom: var(--space-4);
            color: var(--text-secondary);
        }
        
        a {
            color: var(--accent-primary);
            text-decoration: none;
            transition: color var(--transition-fast);
        }
        
        a:hover {
            color: var(--accent-primary-hover);
        }
        
        /* Code styling */
        code {
            font-family: var(--font-mono);
            font-size: 0.875em;
            background-color: var(--bg-code);
            padding: var(--space-1) var(--space-2);
            border-radius: var(--radius-sm);
            color: var(--text-code);
            border: 1px solid var(--border-light);
        }
        
        pre {
            margin: var(--space-6) 0;
            padding: var(--space-6);
            background-color: var(--bg-code);
            border-radius: var(--radius-lg);
            overflow-x: auto;
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow-sm);
        }
        
        pre code {
            background: none;
            padding: 0;
            border: none;
            font-size: 0.9375em;
            line-height: var(--leading-relaxed);
        }
        
        /* Lists */
        ul, ol {
            margin-bottom: var(--space-4);
            padding-left: var(--space-6);
            color: var(--text-secondary);
        }
        
        li {
            margin-bottom: var(--space-2);
        }
        
        /* Blockquotes */
        blockquote {
            margin: var(--space-6) 0;
            padding: var(--space-4) var(--space-6);
            border-left: 4px solid var(--accent-primary);
            background-color: var(--bg-tertiary);
            border-radius: 0 var(--radius-md) var(--radius-md) 0;
            font-style: italic;
            color: var(--text-primary);
        }
        
        blockquote p {
            margin-bottom: 0;
            font-size: var(--text-lg);
        }
        
        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin: var(--space-6) 0;
            font-size: var(--text-sm);
        }
        
        th, td {
            padding: var(--space-3) var(--space-4);
            text-align: left;
            border-bottom: 1px solid var(--border-light);
        }
        
        th {
            font-weight: var(--font-weight-semibold);
            color: var(--text-primary);
            background-color: var(--bg-tertiary);
        }
        
        tbody tr:hover {
            background-color: var(--bg-tertiary);
        }
        
        /* Horizontal rule */
        hr {
            border: none;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--border-light), transparent);
            margin: var(--space-8) 0;
        }
        
        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: var(--space-2);
            padding: var(--space-3) var(--space-6);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            font-family: var(--font-sans);
            font-size: var(--text-sm);
            font-weight: var(--font-weight-medium);
            text-decoration: none;
            cursor: pointer;
            transition: all var(--transition-fast);
            position: relative;
            overflow: hidden;
            white-space: nowrap;
        }
        
        .btn:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }
        
        .btn-ghost {
            background-color: transparent;
            color: var(--text-secondary);
            border-color: transparent;
        }
        
        .btn-ghost:hover {
            background-color: var(--bg-tertiary);
            color: var(--text-primary);
            border-color: var(--border-medium);
        }
        
        .btn-sm {
            padding: var(--space-2) var(--space-4);
            font-size: var(--text-xs);
        }
        
        /* Responsive fixes */
        @media (max-width: 768px) {
            .header-container,
            .main-container {
                padding: 0 var(--space-4);
            }
            
            .main-container {
                gap: var(--space-6);
            }
            
            article {
                padding: var(--space-6);
                border-radius: var(--radius-lg);
            }
            
            .sidebar {
                position: static;
                max-height: none;
                margin-bottom: var(--space-6);
            }
        }
        
        @media (max-width: 480px) {
            .header-container,
            .main-container {
                padding: 0 var(--space-3);
            }
            
            article {
                padding: var(--space-4);
                border-radius: var(--radius-lg);
            }
        }
    </style>
</head>
<body class="light">
    <div id="page-wrapper">
        {{{ header }}}
        <div id="content">
            <main>
                {{{ content }}}
            </main>
            {{{ footer }}}
        </div>
        {{{ search_input }}}
        {{{ search_results }}}
    </div>
</body>
</html>
